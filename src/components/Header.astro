---
---
<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="brand">
      <img src="/assets/images/logo.png" alt="むすびかなでる ロゴ" class="brand-logo">
      <span class="brand-text">むすびかなでる</span>
    </a>
    <nav class="site-nav" id="site-nav">
      <ul>
        <li><a href="/#solution">サービス</a></li>
        <li><a href="/#case">導入事例</a></li>
        <li><a href="/tools">ツール紹介</a></li>
        <li><a href="/column">コラム</a></li>
        <li class="has-submenu">
          <a href="/#about" class="submenu-trigger" aria-haspopup="true" aria-expanded="false">私たちについて</a>
          <ul class="submenu">
            <li><a href="/#philosophy">経営理念</a></li>
            <li><a href="/#about">代表者紹介</a></li>
            <li><a href="/#partner">パートナーシップ</a></li>
          </ul>
        </li>
        <li><a href="/#contact" class="btn-contact">お問い合わせ</a></li>
      </ul>
    </nav>
    <button class="nav-toggle" id="nav-toggle" aria-label="メニューを開く">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<script>
  const toggle = document.getElementById('nav-toggle');
  const nav = document.getElementById('site-nav');
  toggle?.addEventListener('click', () => {
    nav?.classList.toggle('is-open');
    toggle.classList.toggle('is-open');
  });

  // モバイルでサブメニューをタップ展開
  const submenuTriggers = document.querySelectorAll('.has-submenu > .submenu-trigger');
  submenuTriggers.forEach((trigger) => {
    trigger.addEventListener('click', (e) => {
      if (window.matchMedia('(max-width: 768px)').matches) {
        const parent = trigger.parentElement;
        if (parent && !parent.classList.contains('is-open')) {
          e.preventDefault();
          document.querySelectorAll('.has-submenu.is-open').forEach((el) => {
            if (el !== parent) el.classList.remove('is-open');
          });
          parent.classList.add('is-open');
          trigger.setAttribute('aria-expanded', 'true');
        }
      }
    });
  });
</script>

<style>
  .site-header {
    padding: 0.7rem 0;
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(26,107,104,0.08);
    position: sticky;
    top: 0;
    z-index: 1000;
    transition: all 0.3s ease;
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    transition: transform 0.2s;
  }

  .brand:hover {
      transform: scale(1.03);
  }

  .brand-logo {
      height: 72px;
      width: auto;
  }

  .brand-text {
    font-size: 1.15rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    color: var(--color-text-main);
    font-family: var(--font-family-serif);
  }

  .site-nav > ul {
    display: flex;
    gap: 2rem;
    align-items: center;
    list-style: none;
  }

  .site-nav ul {
    list-style: none;
  }

  .site-nav a {
    font-size: 0.88rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    color: var(--color-text-sub);
    transition: color 0.2s;
    position: relative;
  }

  .site-nav a:not(.btn-contact)::after {
    content: '';
    position: absolute;
    width: 0;
    height: 2px;
    bottom: -4px;
    left: 0;
    background: var(--color-brand-primary);
    transition: width 0.25s;
    border-radius: 2px;
  }

  .site-nav a:not(.btn-contact):hover {
    color: var(--color-brand-primary);
  }

  .site-nav a:not(.btn-contact):hover::after {
    width: 100%;
  }

  /* ===== サブメニュー ===== */
  .has-submenu {
    position: relative;
  }

  .submenu-trigger::before {
    content: '';
    display: inline-block;
    width: 0.4em;
    height: 0.4em;
    border-right: 2px solid currentColor;
    border-bottom: 2px solid currentColor;
    transform: rotate(45deg) translateY(-2px);
    margin-right: 0.4em;
    vertical-align: middle;
    transition: transform 0.25s;
    opacity: 0.7;
  }

  .has-submenu:hover .submenu-trigger::before,
  .has-submenu.is-open .submenu-trigger::before {
    transform: rotate(225deg) translateY(0);
    opacity: 1;
  }

  .submenu {
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%) translateY(8px);
    min-width: 140px;
    background: rgba(255, 255, 255, 0.98);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(26,107,104,0.1);
    border-radius: 6px;
    box-shadow: 0 8px 24px rgba(0,0,0,0.08);
    padding: 0.25rem 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.2s ease, transform 0.2s ease, visibility 0.2s;
    margin-top: 8px;
  }

  /* ホバーが途切れないよう、トリガーとサブメニュー間に透明な橋渡し */
  .has-submenu::after {
    content: '';
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    height: 16px;
  }

  .has-submenu:hover .submenu,
  .has-submenu:focus-within .submenu {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
  }

  .submenu li {
    width: 100%;
  }

  .submenu a {
    display: block;
    padding: 0.35rem 0.9rem;
    font-size: 0.82rem;
    font-weight: 600;
    line-height: 1.3;
    color: var(--color-text-sub);
    white-space: nowrap;
    transition: background 0.18s, color 0.18s;
  }

  .submenu a::after {
    display: none !important;
  }

  .submenu a:hover {
    background: rgba(26,107,104,0.06);
    color: var(--color-brand-primary);
  }

  .btn-contact {
    display: inline-block;
    padding: 0.55rem 1.3rem;
    background: var(--color-brand-primary);
    color: #fff !important;
    border-radius: 4px;
    font-weight: 700;
    font-size: 0.88rem;
    box-shadow: var(--shadow-brand);
    transition: background 0.2s, transform 0.2s;
  }

  .btn-contact:hover {
    background: var(--color-brand-primary-dark);
    transform: translateY(-2px);
  }

  .nav-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }

  .nav-toggle span {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--color-text-main);
    border-radius: 2px;
    transition: all 0.3s;
  }

  @media (max-width: 768px) {
    .site-header {
      padding: 0.55rem 0;
    }

    .brand {
      gap: 0.55rem;
    }

    .brand-logo {
      height: 52px;
    }

    .brand-text {
      font-size: 0.95rem;
      letter-spacing: 0.04em;
    }

    .nav-toggle {
      display: flex;
    }

    .site-nav {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background: #fff;
      border-top: 1px solid var(--color-bg-muted);
      box-shadow: var(--shadow-md);
      padding: 1.5rem;
    }

    .site-nav.is-open {
      display: block;
    }

    .site-nav > ul {
      flex-direction: column;
      gap: 1rem;
      align-items: flex-start;
    }

    /* モバイル: サブメニューはアコーディオン的に展開 */
    .has-submenu {
      width: 100%;
    }

    .submenu,
    .submenu li {
      gap: 0;
      margin: 0;
    }

    .has-submenu::after { display: none; }

    .submenu {
      position: static;
      transform: none;
      box-shadow: none;
      border: none;
      background: transparent;
      backdrop-filter: none;
      -webkit-backdrop-filter: none;
      padding: 0.4rem 0 0.2rem 1rem;
      margin-top: 0.4rem;
      min-width: 0;
      max-height: 0;
      overflow: hidden;
      opacity: 0;
      visibility: hidden;
      transition: max-height 0.25s ease, opacity 0.25s ease, visibility 0.25s;
    }

    .has-submenu.is-open .submenu {
      max-height: 300px;
      opacity: 1;
      visibility: visible;
    }

    /* モバイルではホバーで開かない */
    .has-submenu:hover .submenu {
      opacity: 0;
      visibility: hidden;
      transform: none;
    }

    .has-submenu.is-open:hover .submenu,
    .has-submenu.is-open .submenu {
      opacity: 1;
      visibility: visible;
    }

    .submenu a {
      padding: 0.5rem 0;
      font-size: 0.85rem;
    }

    .btn-contact {
      width: 100%;
      text-align: center;
    }
  }

  @media (max-width: 430px) {
    .brand-logo {
      height: 46px;
    }

    .brand-text {
      font-size: 0.88rem;
    }

    .site-nav {
      padding: 1rem;
    }
  }
</style>
